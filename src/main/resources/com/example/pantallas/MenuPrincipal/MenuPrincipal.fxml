<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="800.0" prefWidth="1250.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pantallas.MenuPrincipal.MenuPrincipalController">
    <children>
        <VBox prefWidth="280.0" style="-fx-background-color: #1a2a3a;">
            <children>
                <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 40 20 30 20;">
                    <children>
                        <Label text="🧀" style="-fx-font-size: 60;" />
                        <Label text="PANEL PRINCIPAL" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label text="Fábrica de Queso" textFill="#95a5a6">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Separator opacity="0.2" prefWidth="200.0" />
                    </children>
                </VBox>



                <Region VBox.vgrow="ALWAYS" />

                <VBox style="-fx-padding: 20;">
                    <children>
                        <Button maxWidth="Infinity" onAction="#salir" prefHeight="45.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="SALIR DEL SISTEMA" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="40.0" style="-fx-padding: 60 80;">
            <children>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Bienvenido al Sistema de Gestión" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                        <Label text="Seleccione un módulo para comenzar a trabajar" textFill="#7f8c8d">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <TilePane alignment="CENTER" hgap="30.0" prefColumns="3" vgap="30.0">
                    <children>
                        <Button onAction="#abrirCompras" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="COMPRAS" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button onAction="#abrirVentas" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="VENTAS" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button onAction="#abrirInventario" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="INVENTARIO" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button onAction="#abrirProduccion" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="PRODUCCIÓN" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button onAction="#abrirDistribucion" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="DISTRIBUCIÓN" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button onAction="#abrirMantenimiento" prefHeight="180.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-cursor: hand;" text="MANTENIMIENTO" textAlignment="CENTER">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                    </children>
                </TilePane>
            </children>
        </VBox>
    </children>
</HBox>