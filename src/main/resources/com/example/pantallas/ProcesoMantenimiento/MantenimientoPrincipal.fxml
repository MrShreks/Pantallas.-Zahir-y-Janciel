<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="750.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pantallas.ProcesoDeMantenimiento.MantenimientoController">
    <children>
        <VBox prefWidth="260.0" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="SISTEMA DE MANTENIMIENTO" />
                <Separator opacity="0.3" />

                <Button maxWidth="Infinity" onAction="#irAEquipos" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="1. Gestión de Equipos" />
                <Button maxWidth="Infinity" onAction="#irAPlanificacion" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="2. Programar Tarea" />
                <Button maxWidth="Infinity" onAction="#irAHistorial" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="3. Historial / Pendientes" />

                <Region VBox.vgrow="ALWAYS" />

                <Separator opacity="0.3" />
                <Button maxWidth="Infinity" onAction="#volverMenu" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="VOLVER AL MENÚ" />
            </children>
        </VBox>

        <StackPane HBox.hgrow="ALWAYS" style="-fx-background-color: #ecf0f1;">
            <children>

                <VBox fx:id="paneEquipos" spacing="15" style="-fx-padding: 25;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Inventario de Maquinaria" />

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" />
                            <ColumnConstraints minWidth="250" />
                        </columnConstraints>
                        <children>
                            <Label text="Nombre Equipo:" GridPane.rowIndex="0" />
                            <TextField fx:id="txtNombreEquipo" promptText="Ej: Pasteurizadora" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <Label text="Modelo/Serie:" GridPane.rowIndex="1" />
                            <TextField fx:id="txtModelo" promptText="Ej: PV-2024" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <Label text="Estado Actual:" GridPane.rowIndex="2" />
                            <ComboBox fx:id="cbEstadoEquipo" prefWidth="250" promptText="Seleccionar estado" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        </children>
                    </GridPane>

                    <HBox spacing="10" style="-fx-padding: 10 0;">
                        <Button onAction="#guardarEquipo" prefWidth="110" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar" />
                        <Button onAction="#actualizarEquipo" prefWidth="110" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="Actualizar" />
                        <Button onAction="#borrarEquipo" prefWidth="110" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;" text="Borrar" />
                        <Button onAction="#limpiarCampos" prefWidth="110" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold;" text="Limpiar" />
                    </HBox>

                    <TableView fx:id="tablaMaquinaria" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="220" text="Nombre" />
                            <TableColumn fx:id="colModelo" prefWidth="180" text="Modelo" />
                            <TableColumn fx:id="colEstado" prefWidth="140" text="Estado" />
                            <TableColumn fx:id="colUltimoManto" prefWidth="160" text="Último Manto." />
                        </columns>
                    </TableView>
                </VBox>

                <VBox fx:id="panePlanificacion" managed="false" visible="false" spacing="20" style="-fx-padding: 30;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Programar Nuevo Mantenimiento" />
                    <VBox maxWidth="450" spacing="15">
                        <Label text="Seleccione el Equipo:" />
                        <ComboBox fx:id="cbEquipos" prefWidth="450" />
                        <Label text="Fecha Programada:" />
                        <DatePicker fx:id="dpFechaManto" prefWidth="200" />
                        <Label text="Tipo de Intervención:" />
                        <HBox spacing="30">
                            <RadioButton fx:id="rbPreventivo" text="Preventivo" />
                            <RadioButton fx:id="rbCorrectivo" text="Correctivo" />
                        </HBox>
                        <Button onAction="#programarTarea" prefHeight="45" prefWidth="200" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;" text="AGENDAR TAREA" />
                    </VBox>
                </VBox>

                <VBox fx:id="paneHistorial" managed="false" visible="false" spacing="15" style="-fx-padding: 25;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Historial de Tareas" />
                    <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHistFecha" prefWidth="130" text="Fecha Programada" />
                            <TableColumn fx:id="colHistEquipo" prefWidth="220" text="Equipo" />
                            <TableColumn fx:id="colHistTipo" prefWidth="130" text="Tipo" />
                            <TableColumn fx:id="colHistEstado" prefWidth="130" text="Estado Tarea" />
                            <TableColumn fx:id="colHistAccion" prefWidth="150" text="Cambiar Estado" />
                        </columns>
                    </TableView>
                </VBox>

            </children>
        </StackPane>
    </children>
</HBox>